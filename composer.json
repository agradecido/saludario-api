{
    "name": "saludario/api",
    "description": "Backend API for Saludario in plain PHP",
    "type": "project",
    "require": {
        "php": "^8.3",
        "nikic/fast-route": "^1.3",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "robmorgan/phinx": "^0.16"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "start": "php -S 0.0.0.0:3000 -t public"
    }
}
