{
  "openapi": "3.0.3",
  "info": {
    "title": "Saludario API",
    "version": "0.1.0",
    "description": "Importable MVP API specification for Saludario. Based on the current contract docs."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Health"
    },
    {
      "name": "Auth"
    },
    {
      "name": "Categories"
    },
    {
      "name": "Entries"
    },
    {
      "name": "Symptoms"
    }
  ],
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register user",
        "operationId": "registerUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created and session established",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "409": {
            "$ref": "#/components/responses/ConflictError"
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login user",
        "operationId": "loginUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session established",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitedError"
          }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout user",
        "operationId": "logoutUser",
        "description": "Session-aware endpoint. Clears the cookie and revokes the session if present.",
        "responses": {
          "204": {
            "description": "Cookie cleared; if session exists, it is revoked"
          }
        }
      }
    },
    "/api/v1/auth/session": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current session",
        "operationId": "getSession",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current session and user summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/api/v1/categories": {
      "get": {
        "tags": ["Categories"],
        "summary": "List meal categories",
        "operationId": "listCategories",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Fixed MVP meal categories",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CategoriesResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/api/v1/entries": {
      "post": {
        "tags": ["Entries"],
        "summary": "Create food entry",
        "operationId": "createEntry",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEntryRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Entry created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Entry"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      },
      "get": {
        "tags": ["Entries"],
        "summary": "List food entries",
        "operationId": "listEntries",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "meal_category_code",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/MealCategoryCode"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated entries ordered by consumed_at desc, id desc",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntryListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/api/v1/entries/{entry_id}": {
      "get": {
        "tags": ["Entries"],
        "summary": "Get food entry by id",
        "operationId": "getEntryById",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/EntryId"
          }
        ],
        "responses": {
          "200": {
            "description": "Entry found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Entry"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        }
      },
      "patch": {
        "tags": ["Entries"],
        "summary": "Update food entry",
        "operationId": "updateEntry",
        "description": "Partial update. MVP behavior is last-write-wins.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/EntryId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateEntryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Entry"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        }
      },
      "delete": {
        "tags": ["Entries"],
        "summary": "Delete food entry",
        "operationId": "deleteEntry",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/EntryId"
          }
        ],
        "responses": {
          "204": {
            "description": "Entry deleted"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        }
      }
    },
    "/api/v1/internal/symptoms/events": {
      "post": {
        "tags": ["Symptoms"],
        "summary": "Create symptom event",
        "operationId": "createSymptomEvent",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSymptomEventRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Symptom event created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SymptomEvent"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      },
      "get": {
        "tags": ["Symptoms"],
        "summary": "List symptom events",
        "operationId": "listSymptomEvents",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "symptom_code",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated symptom events ordered by occurred_at desc, id desc",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SymptomEventListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/api/v1/internal/symptoms/events/{symptom_event_id}": {
      "get": {
        "tags": ["Symptoms"],
        "summary": "Get symptom event by id",
        "operationId": "getSymptomEventById",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/SymptomEventId"
          }
        ],
        "responses": {
          "200": {
            "description": "Symptom event found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SymptomEvent"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "saludario_session"
      }
    },
    "parameters": {
      "EntryId": {
        "name": "entry_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "SymptomEventId": {
        "name": "symptom_event_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "responses": {
      "ValidationError": {
        "description": "Validation error",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      },
      "UnauthorizedError": {
        "description": "Unauthorized",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      },
      "ConflictError": {
        "description": "Conflict",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      },
      "NotFoundError": {
        "description": "Not found",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      },
      "RateLimitedError": {
        "description": "Too many requests",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "required": ["type", "title", "status", "code"],
        "properties": {
          "type": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "detail": {
            "type": "string"
          },
          "instance": {
            "type": "string"
          },
          "code": {
            "type": "string",
            "enum": [
              "VALIDATION_ERROR",
              "UNAUTHORIZED",
              "FORBIDDEN",
              "NOT_FOUND",
              "CONFLICT",
              "RATE_LIMITED",
              "INTERNAL_ERROR"
            ]
          },
          "request_id": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FieldError"
            }
          }
        },
        "additionalProperties": true
      },
      "FieldError": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        },
        "required": ["field", "message"]
      },
      "MealCategoryCode": {
        "type": "string",
        "enum": ["breakfast", "lunch", "dinner", "snack"]
      },
      "UserSummary": {
        "type": "object",
        "required": ["id", "email", "timezone"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "timezone": {
            "type": "string",
            "example": "Europe/Madrid"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "timezone": {
            "type": "string",
            "default": "UTC"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "required": ["user"],
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserSummary"
          }
        }
      },
      "SessionSummary": {
        "type": "object",
        "required": ["expires_at"],
        "properties": {
          "expires_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SessionResponse": {
        "type": "object",
        "required": ["session", "user"],
        "properties": {
          "session": {
            "$ref": "#/components/schemas/SessionSummary"
          },
          "user": {
            "$ref": "#/components/schemas/UserSummary"
          }
        }
      },
      "Category": {
        "type": "object",
        "required": ["code", "label", "sort_order"],
        "properties": {
          "code": {
            "$ref": "#/components/schemas/MealCategoryCode"
          },
          "label": {
            "type": "string"
          },
          "sort_order": {
            "type": "integer"
          }
        }
      },
      "CategoriesResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Category"
            }
          }
        }
      },
      "Entry": {
        "type": "object",
        "required": [
          "id",
          "user_id",
          "meal_category_code",
          "food_name",
          "consumed_at",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          },
          "meal_category_code": {
            "$ref": "#/components/schemas/MealCategoryCode"
          },
          "food_name": {
            "type": "string"
          },
          "quantity_value": {
            "type": "number"
          },
          "quantity_unit": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "consumed_at": {
            "type": "string",
            "format": "date-time"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateEntryRequest": {
        "type": "object",
        "required": ["meal_category_code", "food_name", "consumed_at"],
        "properties": {
          "meal_category_code": {
            "$ref": "#/components/schemas/MealCategoryCode"
          },
          "food_name": {
            "type": "string"
          },
          "quantity_value": {
            "type": "number"
          },
          "quantity_unit": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "consumed_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UpdateEntryRequest": {
        "type": "object",
        "properties": {
          "meal_category_code": {
            "$ref": "#/components/schemas/MealCategoryCode"
          },
          "food_name": {
            "type": "string"
          },
          "quantity_value": {
            "type": "number"
          },
          "quantity_unit": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "consumed_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "PageInfo": {
        "type": "object",
        "required": ["limit", "has_more"],
        "properties": {
          "limit": {
            "type": "integer"
          },
          "has_more": {
            "type": "boolean"
          },
          "next_cursor": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "EntryListResponse": {
        "type": "object",
        "required": ["data", "page"],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Entry"
            }
          },
          "page": {
            "$ref": "#/components/schemas/PageInfo"
          }
        }
      },
      "SymptomEvent": {
        "type": "object",
        "required": [
          "id",
          "user_id",
          "symptom_code",
          "severity",
          "occurred_at",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          },
          "symptom_code": {
            "type": "string"
          },
          "severity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "occurred_at": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateSymptomEventRequest": {
        "type": "object",
        "required": ["symptom_code", "severity", "occurred_at"],
        "properties": {
          "symptom_code": {
            "type": "string"
          },
          "severity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "occurred_at": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "SymptomEventListResponse": {
        "type": "object",
        "required": ["data", "page"],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SymptomEvent"
            }
          },
          "page": {
            "$ref": "#/components/schemas/PageInfo"
          }
        }
      }
    }
  }
}
